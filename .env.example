# .env.example — Cosmic Query Engine
# Copy this file to .env and fill in real values
# Never commit .env to version control

# ─────────────────────────────────────────────
# Django core
# ─────────────────────────────────────────────

# Generate with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=your-django-secret-key-here

# Set to False in production
DJANGO_DEBUG=True

# Comma-separated list of allowed hosts
# Example: localhost,127.0.0.1,yourdomain.com
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# ─────────────────────────────────────────────
# Database (PostgreSQL)
# ─────────────────────────────────────────────

DB_NAME=cosmic_query
DB_USER=postgres
DB_PASSWORD=your-db-password-here
DB_HOST=localhost
DB_PORT=5432

# ─────────────────────────────────────────────
# Redis (session context + Celery broker)
# ─────────────────────────────────────────────

REDIS_URL=redis://localhost:6379/0

# Session TTL in seconds (default: 1800 = 30 minutes)
SESSION_TTL_SECONDS=1800

# ─────────────────────────────────────────────
# Anthropic Claude API (LLM — server-side only)
# ─────────────────────────────────────────────

# Used by: S-09 Philosophy head, S-10 I Ching query application, S-11 Synthesis
# Never expose this key to any client surface
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Model to use for all LLM calls
# Recommended: claude-sonnet-4-5 for balance of quality and cost
ANTHROPIC_MODEL=claude-sonnet-4-5

# Max tokens for synthesis output (S-11)
ANTHROPIC_MAX_TOKENS=1500

# ─────────────────────────────────────────────
# Swiss Ephemeris (astronomical calculations)
# ─────────────────────────────────────────────

# Path to Swiss Ephemeris data files
# Download from: https://www.astro.com/swisseph/ephe/
# Required files: seas_18.se1, sepl_18.se1, semo_18.se1
SWISSEPH_PATH=./backend/ephe

# ─────────────────────────────────────────────
# Profile storage encryption
# ─────────────────────────────────────────────

# Used to encrypt birth data at rest in PostgreSQL
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
PROFILE_ENCRYPTION_KEY=your-fernet-key-here

# ─────────────────────────────────────────────
# Geocoding (city + country → coordinates)
# ─────────────────────────────────────────────

# Used by S-01 to resolve birth city + country to coordinates
# Options: Google Maps Geocoding API or OpenCage
# OpenCage is cheaper for low volume: https://opencagedata.com
GEOCODING_API_KEY=your-geocoding-key-here
GEOCODING_PROVIDER=opencage

# ─────────────────────────────────────────────
# Celery (parallel head engine execution)
# ─────────────────────────────────────────────

CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ─────────────────────────────────────────────
# CORS (frontend origins allowed to call the API)
# ─────────────────────────────────────────────

# Comma-separated list of allowed origins
# Example: http://localhost:5173,https://yourdomain.com
CORS_ALLOWED_ORIGINS=http://localhost:5173

# ─────────────────────────────────────────────
# Rate limiting
# ─────────────────────────────────────────────

# Maximum sessions per user per minute (S-14 spec)
MAX_SESSIONS_PER_MINUTE=1

# Maximum queries per session (S-14 spec)
MAX_QUERIES_PER_SESSION=3

# ─────────────────────────────────────────────
# Optional: Push notifications (mobile — v0.1 optional)
# ─────────────────────────────────────────────

# Firebase Cloud Messaging for Flutter push notifications
# Leave blank to disable push notifications in v0.1
FCM_SERVER_KEY=

# Seconds of backgrounding before push notification fires
PUSH_NOTIFICATION_DELAY_SECONDS=60
